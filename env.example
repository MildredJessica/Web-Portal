# ── Database ──────────────────────────────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/insighta_labs"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# NODE_ENV options: development | production | test

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace_with_64_byte_random_hex_string"

# Access token lifetime — keep short (spec: 3 minutes)
ACCESS_TOKEN_EXPIRY="3m"

# Refresh token lifetime in milliseconds (spec: 5 minutes = 300000)
REFRESH_TOKEN_EXPIRY_MS=300000

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# Create an OAuth App at: https://github.com/settings/developers
#   Homepage URL:              https://backend-com.up.railway.app
#   Authorization callback URL: https://backend-com.up.railway.app/auth/github/callback
GITHUB_CLIENT_ID="your_github_oauth_app_client_id"
GITHUB_CLIENT_SECRET="your_github_oauth_app_client_secret"
GITHUB_CALLBACK_URL="backend-com.up.railway.app/auth/github/callback"

# ── CORS / Frontend ───────────────────────────────────────────────────────────
# URL of the web portal (used for CORS and post-login redirect)
FRONTEND_URL="https://web-portal-weld-eta.vercel.app"

# ── Cookies ───────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Must be different from JWT_SECRET
COOKIE_SECRET="replace_with_another_64_byte_random_hex_string"
VITE_API_URL= "https://backend-com.up.railway.app"
PORT = 4000